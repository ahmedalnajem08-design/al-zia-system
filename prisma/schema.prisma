datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==================== المستخدمون والصلاحيات ====================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?
  password  String
  phone     String?
  role      String   @default("user") // admin, manager, user
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== المخازن ====================

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stocks    WarehouseStock[]
  invoices  Invoice[]
}

model WarehouseStock {
  id          String   @id @default(cuid())
  warehouseId String
  productId   String
  unitId      String?
  quantity    Float    @default(0)
  minStock    Float    @default(0)
  updatedAt   DateTime @updatedAt

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])
  unit        ProductUnit? @relation(fields: [unitId], references: [id])

  @@unique([warehouseId, productId, unitId])
}

// ==================== المواد / المنتجات ====================

model Product {
  id          String         @id @default(cuid())
  name        String
  sku         String?
  barcode     String?
  categoryId  String?
  description String?
  costPrice   Float          @default(0)
  sellPrice   Float          @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  units       ProductUnit[]
  stocks      WarehouseStock[]
  invoiceItems InvoiceItem[]
}

model ProductCategory {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  products  Product[]
}

// وحدات التعبئة المتعددة
model ProductUnit {
  id          String   @id @default(cuid())
  productId   String
  name        String   // قطعة، كرتونة، باك، طن، كيلو...
  barcode     String?
  conversionFactor Float @default(1) // معامل التحويل من الوحدة الأساسية
  costPrice   Float    @default(0)
  sellPrice   Float    @default(0)
  isDefault   Boolean  @default(false)

  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  stocks        WarehouseStock[]
  invoiceItems  InvoiceItem[]

  @@unique([productId, name])
}

// ==================== الحسابات ====================

model Customer {
  id         String   @id @default(cuid())
  name       String
  phone      String?
  address    String?
  email      String?
  taxNumber  String?
  notes      String?
  balance    Float    @default(0) // رصيد الحساب
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  invoices   Invoice[]
  payments   Payment[]
  vouchers   Voucher[]
}

model Supplier {
  id         String   @id @default(cuid())
  name       String
  phone      String?
  address    String?
  email      String?
  taxNumber  String?
  notes      String?
  balance    Float    @default(0) // رصيد الحساب
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  invoices   Invoice[]
  payments   Payment[]
  vouchers   Voucher[]
}

// ==================== الفواتير ====================

model Invoice {
  id          String   @id @default(cuid())
  type        String   // sale, purchase, sale_return, purchase_return
  invoiceNo   String   @unique
  customerId  String?
  supplierId  String?
  warehouseId String
  date        DateTime @default(now())
  subtotal    Float    @default(0)
  discount    Float    @default(0)
  tax         Float    @default(0)
  total       Float    @default(0)
  paidAmount  Float    @default(0)
  notes       String?
  status      String   @default("draft") // draft, confirmed, cancelled
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer?    @relation(fields: [customerId], references: [id])
  supplier    Supplier?    @relation(fields: [supplierId], references: [id])
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id])
  items       InvoiceItem[]
  payments    Payment[]
}

model InvoiceItem {
  id           String  @id @default(cuid())
  invoiceId    String
  productId    String
  unitId       String?
  productName  String
  unitName     String?
  quantity     Float
  price        Float
  total        Float
  costPrice    Float   @default(0) // سعر التكلفة لاحتساب الربح

  invoice      Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id])
  unit         ProductUnit? @relation(fields: [unitId], references: [id])
}

// ==================== المدفوعات ====================

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String?
  customerId  String?
  supplierId  String?
  amount      Float
  method      String   // cash, card, transfer
  date        DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())

  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])
  customer    Customer? @relation(fields: [customerId], references: [id])
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
}

// ==================== سندات القبض والدفع ====================

model Voucher {
  id          String   @id @default(cuid())
  voucherNo   String   @unique
  type        String   // receipt, payment
  customerId  String?
  supplierId  String?
  amount      Float
  method      String   @default("cash") // cash, card, transfer, cheque
  description String?
  date        DateTime @default(now())
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer? @relation(fields: [customerId], references: [id])
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
}

// ==================== سندات الصرف / المصروفات ====================

model Expense {
  id          String   @id @default(cuid())
  expenseNo   String   @unique
  amount      Float
  category    String   @default("أخرى") // إيجار, مرافق, رواتب, صيانة, نقل, أخرى
  description String
  date        DateTime @default(now())
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
